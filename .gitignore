node_modules/
dist/
dist-tauri/
release/

# Tauri Rust target dir + generated bundle output
src-tauri/target/
src-tauri/gen/
*.log
.DS_Store

# Local environment (not committed)
.envrc
.env.local
.bat-tauri-dev-profile/
.bat-tauri-dev-local-profile/

# Windows reserved device names (accidentally created by /dev/null redirects)
nul

# Diagnosis reports
tests/*.json

# Bundled Node runtime (fetched per-platform via scripts/fetch-node-runtime.mjs).
# We track the dir itself + its docs so the Tauri bundle.resources entry
# resolves, but the actual binaries are too large + platform-specific to commit.
node-sidecar/runtime/*
!node-sidecar/runtime/.gitkeep
!node-sidecar/runtime/README.md

# Minimal release-only sidecar node_modules tree generated by
# scripts/prepare-tauri-sidecar-node-modules.mjs.
node-sidecar/dist-node_modules/

# Rust-owned Codex app-server runtime generated by
# scripts/prepare-tauri-codex-runtime.mjs.
codex-runtime/
