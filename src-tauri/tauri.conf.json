{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BetterAgentTerminal",
  "version": "2.1.3",
  "identifier": "com.tonyq.better-agent-terminal",
  "build": {
    "beforeDevCommand": "pnpm exec vite --config vite.tauri.config.ts",
    "beforeBuildCommand": "pnpm exec vite build --config vite.tauri.config.ts",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist-tauri"
  },
  "app": {
    "windows": [
      {
        "title": "Better Agent Terminal",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../node-sidecar/dist/server.mjs": "node-sidecar/dist/server.mjs",
      "../node-sidecar/package.json": "node-sidecar/package.json",
      "../node-sidecar/node_modules/": "node-sidecar/node_modules/",
      "../node-sidecar/runtime/": "node-runtime/"
    }
  }
}
