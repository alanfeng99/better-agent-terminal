{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BetterAgentTerminal",
  "mainBinaryName": "BetterAgentTerminal",
  "version": "0.0.1-dev",
  "identifier": "org.tonyq.better-agent-terminal",
  "build": {
    "beforeDevCommand": "pnpm exec vite",
    "beforeBuildCommand": "pnpm exec vite build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist-tauri"
  },
  "app": {
    "windows": [
      {
        "title": "Better Agent Terminal",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../node-sidecar/dist/server.mjs": "node-sidecar/dist/server.mjs",
      "../node-sidecar/package.json": "node-sidecar/package.json"
    },
    "windows": {
      "nsis": {
        "compression": "zlib",
        "installMode": "perMachine",
        "template": "windows/installer.nsi",
        "installerHooks": "windows/nsis-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdGQjFGMzI4NEQxODY5QjcKUldTM2FSaE5LUE94ZjcwMEI5dDYyYmd5WWk2UzFKSFp5bjRXeEFjZisrWmk2L1VOV0Mrc0F6T0gK",
      "endpoints": [
        "https://github.com/tony1223/better-agent-terminal/releases/download/manifests/latest-stable-all-in-one.json"
      ]
    }
  }
}
