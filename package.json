{
  "name": "better-agent-terminal",
  "version": "0.0.1-dev",
  "description": "Windows terminal aggregator with multi-workspace support and Claude Code integration",
  "author": "TonyQ CO., LTD.",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm run tauri:dev:local",
    "compile": "vite build",
    "start": "pnpm run tauri:dev",
    "start:server": "node bin/bat-server.js",
    "build": "pnpm run tauri:build",
    "build:release": "node scripts/build-version.js",
    "update:release-version": "node scripts/build-version.js --skip-build",
    "verify:packaged-claude-binaries": "node scripts/verify-packaged-claude-binaries.js",
    "verify:release-asset-sizes": "node scripts/verify-release-asset-sizes.js",
    "verify:tauri-resources": "node scripts/check-tauri-resources.mjs --strict-missing --max-files=7000 --max-mb=600",
    "verify:tauri-preview-readiness": "node scripts/check-tauri-preview-readiness.mjs",
    "verify:tauri-pre-ci": "pnpm exec tsc --noEmit --pretty false && pnpm run compile && pnpm run prepare:tauri-bundle:ci && pnpm run test:tauri-rust && pnpm run test:sidecar && pnpm run test:host-api && pnpm run test:host-direct-calls && pnpm run test:host-claude-coverage && pnpm run test:codex && pnpm run test:openai-cleanup && pnpm run test:claude-message-guards && pnpm run test:workspace-restore && pnpm run test:renderer-logging && pnpm run test:tauri-bundle-prune && pnpm run test:tauri-resources && pnpm run test:release-asset-names && pnpm run test:tauri-capabilities && pnpm run test:tauri-version-sync && pnpm run test:tauri-windows-installer && pnpm run test:tauri-sidecar-minimal-modules && pnpm run test:build-version-script && pnpm run test:rust-base-cache-key && pnpm run test:tauri-resource-cache-keys && pnpm run test:tauri-preview-readiness && pnpm run verify:tauri-resources && pnpm run verify:tauri-preview-readiness",
    "verify:tauri-release-ci": "pnpm run prepare:tauri-bundle:ci && pnpm run verify:tauri-resources && pnpm run verify:tauri-preview-readiness",
    "verify:tauri-preview": "pnpm run verify:tauri-pre-ci && pnpm run test:tauri-launch",
    "test:console": "node tests/console-test.js",
    "test:codex-panel": "tsx tests/codex-panel-regression.test.ts",
    "test:codex-auto-continue": "tsx tests/codex-auto-continue.test.ts",
    "test:codex": "pnpm run test:codex-panel && pnpm run test:codex-auto-continue",
    "test:openai-cleanup": "tsx tests/openai-direct-cleanup.test.ts",
    "test:claude-message-guards": "tsx tests/claude-message-guards.test.ts",
    "test:workspace-restore": "tsx tests/workspace-restore-focus.test.ts",
    "test:renderer-logging": "tsx tests/renderer-logging.test.ts",
    "test:host-direct-calls": "tsx tests/host-direct-calls.test.ts",
    "test:host-claude-coverage": "tsx tests/host-claude-coverage.test.ts",
    "test:host-api": "tsx tests/host-api.test.ts",
    "test:tauri-launch": "tsx tests/tauri-launch.test.ts",
    "test:tauri-dynamic-window-smoke": "tsx tests/tauri-dynamic-window-smoke.test.ts",
    "test:tauri-capabilities": "node tests/tauri-capabilities.test.mjs",
    "test:tauri-version-sync": "node tests/tauri-version-sync.test.mjs",
    "test:tauri-windows-installer": "node tests/tauri-windows-installer.test.mjs",
    "test:tauri-sidecar-minimal-modules": "node tests/tauri-sidecar-minimal-modules.test.mjs",
    "test:build-version-script": "node tests/build-version-script.test.mjs",
    "test:rust-base-cache-key": "node tests/rust-base-cache-key.test.mjs",
    "test:tauri-resource-cache-keys": "node tests/tauri-resource-cache-keys.test.mjs",
    "test:tauri-rust": "cd src-tauri && cargo test --quiet",
    "test:sidecar": "node node-sidecar/tests/server.test.mjs",
    "test:tauri-bundle-prune": "node tests/prune-node-sidecar-modules.test.mjs",
    "test:tauri-resources": "node tests/check-tauri-resources.test.mjs",
    "test:release-asset-names": "node tests/normalize-release-asset-names.test.mjs",
    "test:tauri-preview-readiness": "node tests/check-tauri-preview-readiness.test.mjs",
    "fetch:node-runtime": "node scripts/fetch-node-runtime.mjs",
    "build:tauri-sidecar": "node scripts/build-node-sidecar.mjs",
    "prune:tauri-sidecar": "node scripts/prune-node-sidecar-modules.mjs",
    "prepare:tauri-sidecar-node-modules": "node scripts/prepare-tauri-sidecar-node-modules.mjs",
    "prepare:tauri-codex-runtime": "node scripts/prepare-tauri-codex-runtime.mjs",
    "prepare:tauri-bundle": "node scripts/fetch-node-runtime.mjs && pnpm --dir node-sidecar install && pnpm run prune:tauri-sidecar && pnpm run build:tauri-sidecar && pnpm run prepare:tauri-sidecar-node-modules && pnpm run prepare:tauri-codex-runtime",
    "prepare:tauri-bundle:ci": "node scripts/fetch-node-runtime.mjs && pnpm --dir node-sidecar install --frozen-lockfile --prefer-offline && pnpm run prune:tauri-sidecar && pnpm run build:tauri-sidecar && pnpm run prepare:tauri-sidecar-node-modules && pnpm run prepare:tauri-codex-runtime",
    "tauri": "tauri",
    "tauri:dev:local": "node scripts/run-tauri-dev-local.mjs",
    "tauri:dev": "tauri dev",
    "tauri:dev:latest": "pnpm run prepare:tauri-bundle && tauri dev",
    "tauri:build:ci": "pnpm run prepare:tauri-bundle:ci && tauri build",
    "tauri:build:ci:prepared": "tauri build",
    "tauri:build": "pnpm run prepare:tauri-bundle && tauri build",
    "tauri:build:debug:ci": "pnpm run prepare:tauri-bundle:ci && tauri build --debug",
    "tauri:build:debug": "pnpm run prepare:tauri-bundle && tauri build --debug",
    "dev:renderer": "cross-env BAT_DEBUG=1 vite"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.128",
    "@anthropic-ai/claude-code": "^2.1.128",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex": "0.128.0",
    "@vscode/ripgrep": "^1.17.1",
    "better-sqlite3": "^12.5.0",
    "selfsigned": "^5.5.0",
    "uuid": "^14.0.0",
    "ws": "^8.19.0"
  },
  "optionalDependencies": {
    "@img/sharp-darwin-arm64": "^0.34.5",
    "@img/sharp-darwin-x64": "^0.34.5",
    "@img/sharp-libvips-darwin-arm64": "^1.2.4",
    "@img/sharp-libvips-darwin-x64": "^1.2.4",
    "@lydell/node-pty": "^1.1.0",
    "@lydell/node-pty-darwin-arm64": "1.1.0",
    "@lydell/node-pty-darwin-x64": "1.1.0",
    "@lydell/node-pty-linux-arm64": "1.1.0",
    "@lydell/node-pty-linux-x64": "1.1.0",
    "@lydell/node-pty-win32-arm64": "1.1.0",
    "@lydell/node-pty-win32-x64": "1.1.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "dompurify": "^3.3.3",
    "esbuild": "^0.28.0",
    "highlight.js": "^11.11.1",
    "i18next": "^25.8.18",
    "marked": "^17.0.5",
    "mermaid": "^11.13.0",
    "png-to-ico": "^3.0.1",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.8",
    "sharp": "^0.34.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.0"
  },
  "overrides": {
    "minimatch@3": "3.1.5",
    "minimatch@5": "5.1.9"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "current"
      ],
      "cpu": [
        "current",
        "x64",
        "arm64"
      ],
      "libc": [
        "current"
      ]
    },
    "onlyBuiltDependencies": [
      "@anthropic-ai/claude-code",
      "@vscode/ripgrep",
      "@lydell/node-pty",
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  },
  "bin": {
    "bat-server": "bin/bat-server.js"
  }
}
