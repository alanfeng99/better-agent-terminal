# Optional local-only Tauri dev profile overrides.
# Copy to .env.local and change the paths for your machine if needed.

# BAT_TAURI_DATA_DIR=/absolute/path/to/bat-tauri-dev-profile
# BAT_SIDECAR_DATA_DIR=/absolute/path/to/bat-tauri-dev-profile

# Procfile.tauri `tauri-dev` uses --isolated-profile and defaults to
# .bat-tauri-dev-local-profile. Use these only if you want a different local
# sandbox for that Procfile entry.
# BAT_TAURI_DEV_DATA_DIR=/absolute/path/to/bat-tauri-dev-local-profile
# BAT_TAURI_DEV_PROFILE_ID=tauri-dev-local
# BAT_TAURI_DEV_PROFILE_NAME=Tauri Dev Local
# BAT_TAURI_DEV_WORKSPACE_PATH=/absolute/path/to/workspace
